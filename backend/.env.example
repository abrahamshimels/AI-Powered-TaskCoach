# Server Configuration
PORT=5000

# Database Configuration
DB_HOST=localhost
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_database_name

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=1d

# AI Service Configuration
AI_SERVICE_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_MODEL=gpt-3.5-turbo
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=cohere/rerank-4-pro
OPENROUTER_MODE=chat
OPENROUTER_RERANK_TOP_N=3
OPENROUTER_RERANK_DOCUMENTS=Paris is the capital of France.||London is the capital of England.||Berlin is the capital of Germany.